{
  "name": "copilot-reviewer-assistant",
  "displayName": "Copilot Reviewer Assistant",
  "description": "GitHub Copilot review suggestions don't always come with an 'Apply' button. This extension fills that gap — fetch every pending Copilot review comment and apply all fixes automatically, straight from VS Code.",
  "version": "1.0.0",
  "publisher": "Veverke",
  "icon": "media/icon.png",
  "license": "MIT AND Commons-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/Veverke/CopilotReviewerAssistant"
  },
  "bugs": {
    "url": "https://github.com/Veverke/CopilotReviewerAssistant/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": ["copilot", "github", "pull request", "code review", "ai"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotReviewer.openPanel",
        "title": "Copilot Reviewer: Open PR Copilot Reviews Panel"
      },
      {
        "command": "copilotReviewer.clearPat",
        "title": "Copilot Reviewer: Clear Stored GitHub PAT"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.5"
  }
}
